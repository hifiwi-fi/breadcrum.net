{
  "name": "@breadcrum/web",
  "description": "The primary web server process in breadcrum.net. Provides API and html web serving.",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#lib/*": "./lib/*",
    "#views/*": "./views/*"
  },
  "private": true,
  "dependencies": {
    "@breadcrum/resources": "workspace:*",
    "@bret/is-youtube-url": "catalog:",
    "@domstack/fastify": "0.0.2",
    "@fastify/accepts": "^5.0.1",
    "@fastify/auth": "^5.0.1",
    "@fastify/autoload": "catalog:",
    "@fastify/basic-auth": "^6.0.1",
    "@fastify/circuit-breaker": "^4.0.1",
    "@fastify/compress": "^8.0.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "catalog:",
    "@fastify/formbody": "^8.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/otel": "catalog:",
    "@fastify/postgres": "catalog:",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/redis": "catalog:",
    "@fastify/sensible": "catalog:",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.1.0",
    "@fastify/swagger-ui": "^5.0.1",
    "@maxmind/geoip2-node": "^6.3.4",
    "@nearform/sql": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/exporter-prometheus": "catalog:",
    "@opentelemetry/host-metrics": "catalog:",
    "@opentelemetry/instrumentation-http": "catalog:",
    "@opentelemetry/instrumentation-runtime-node": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@passwordless-id/webauthn": "^2.3.1",
    "@breadcrum/bookmarklet": "1.0.13",
    "abstract-cache-redis": "catalog:",
    "clean-deep": "^3.4.0",
    "common-tags": "^1.8.2",
    "fast-json-body": "^1.1.0",
    "fastify": "catalog:",
    "fastify-cli": "catalog:",
    "fastify-fragtml": "^0.0.3",
    "fastify-healthcheck": "catalog:",
    "fastify-plugin": "catalog:",
    "fastify-user-agent": "^2.0.0",
    "fragtml": "^0.0.9",
    "giscus": "^1.6.0",
    "htmx.org": "4.0.0-beta4",
    "jsonfeed-to-atom": "^1.2.5",
    "jsonfeed-to-rss": "^3.0.8",
    "markdown-it": "14.1.1",
    "nodemailer": "^8.0.7",
    "pg": "catalog:",
    "postgrator-cli": "^9.0.0",
    "resolve-email": "^4.0.45",
    "undici": "catalog:",
    "useragent": "^2.3.0"
  },
  "devDependencies": {
    "@fastify/type-provider-json-schema-to-ts": "catalog:",
    "@types/common-tags": "^1.8.4",
    "@types/markdown-it": "14.1.2",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "catalog:",
    "@types/useragent": "^2.3.4",
    "@voxpelli/tsconfig": "catalog:",
    "argsclopts": "^1.0.5",
    "eslint": "catalog:",
    "json-schema-to-ts": "^3.1.1",
    "neostandard": "catalog:",
    "npm-run-all2": "catalog:",
    "type-fest": "^5.2.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "run-s clean build:*",
    "build:assets": "node scripts/build-assets.js",
    "build:domstack": "node scripts/build-domstack.js",
    "clean": "rm -rf public && mkdir -p public",
    "migrate": "postgrator",
    "generate-default-env": "node scripts/generate-default-env.js",
    "prod-sim": "fastify start -l info app.js --address 0.0.0.0 --import otel.js",
    "start": "run-s watch",
    "test": "run-s test:*",
    "test:eslint": "eslint . --ignore-pattern 'public/*'",
    "test:node": "node --experimental-test-coverage --test --test-reporter spec --test-reporter-destination stdout --test-reporter lcov --test-reporter-destination lcov.info --test-force-exit --test-concurrency 1",
    "test:tsc": "tsc",
    "watch": "run-s clean && run-p watch:assets watch:server",
    "watch:assets": "node scripts/build-assets.js --watch",
    "watch:server": "fastify start -w --ignore-watch='node_modules .git ./public' -l info -P -p 3000 --options --address 0.0.0.0 app.js",
    "print-routes": "fastify print-routes app.js",
    "print-plugins": "fastify print-plugins app.js --import otel.js",
    "generate-dbml": "pnpm dlx pg-to-dbml --c postgres://postgres@localhost/breadcrum"
  }
}
